@model Nexora.Web.Data.Models.Category
@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Edit Category";
}

<div class="body flex-grow-1 px-3">
    <div class="container-lg">

        <div class="d-flex align-items-center justify-content-between mb-3">
            <div>
                <div class="fs-4 fw-semibold">Edit Category</div>
                <div class="text-medium-emphasis">Update category name</div>
            </div>

            <a class="btn btn-outline-secondary" asp-controller="Categories" asp-action="Index">
                <svg class="icon me-2">
                    <use xlink:href="~/admin/assets/assets/vendors/coreui/icons/svg/free.svg#cil-arrow-left"></use>
                </svg>
                Back
            </a>
        </div>

        <div class="card mb-4">
            <div class="card-header fw-semibold">
                <svg class="icon me-2">
                    <use xlink:href="~/admin/assets/assets/vendors/coreui/icons/svg/free.svg#cil-pencil"></use>
                </svg>
                Edit Category
            </div>
            <div class="card-body">
                <form method="post"
                      asp-controller="Categories"
                      asp-action="Edit"
                      asp-route-id="@Model.Id">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <input name="name" class="form-control" value="@Model.Name" autocomplete="off" />
                        <div class="form-text">Category ID: @Model.Id</div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <svg class="icon me-2">
                                <use xlink:href="~/admin/assets/assets/vendors/coreui/icons/svg/free.svg#cil-save"></use>
                            </svg>
                            Save
                        </button>
                        <a class="btn btn-light" asp-controller="Categories" asp-action="Index">Cancel</a>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>