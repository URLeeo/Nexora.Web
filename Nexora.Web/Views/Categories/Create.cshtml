@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Create Category";
    var coreuiIcons = Url.Content("~/admin/assets/vendors/@coreui/icons/svg/free.svg");
}

<div class="body flex-grow-1 px-3">
    <div class="container-lg">

        <div class="d-flex align-items-center justify-content-between mb-3">
            <div>
                <div class="fs-4 fw-semibold">Create Category</div>
                <div class="text-medium-emphasis">Add a new category</div>
            </div>

            <a class="btn btn-outline-secondary" asp-controller="Categories" asp-action="Index">
                <svg class="icon me-2">
                    <use href="@($"{coreuiIcons}#cil-arrow-left")" xlink:href="@($"{coreuiIcons}#cil-arrow-left")"></use>
                </svg>
                Back
            </a>
        </div>

        <div class="card mb-4">
            <div class="card-header fw-semibold">
                <svg class="icon me-2">
                    <use href="@($"{coreuiIcons}#cil-plus")" xlink:href="@($"{coreuiIcons}#cil-plus")"></use>
                </svg>
                New Category
            </div>

            <div class="card-body">
                <form method="post" asp-controller="Categories" asp-action="Create">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <input name="name"
                               class="form-control"
                               placeholder="e.g. Electronics"
                               value="@(ViewBag.Name as string ?? "")"
                               autocomplete="off" />
                        <div class="form-text">Unique within your organization.</div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <svg class="icon me-2">
                                <use href="@($"{coreuiIcons}#cil-save")" xlink:href="@($"{coreuiIcons}#cil-save")"></use>
                            </svg>
                            Create
                        </button>
                        <a class="btn btn-light" asp-controller="Categories" asp-action="Index">Cancel</a>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>