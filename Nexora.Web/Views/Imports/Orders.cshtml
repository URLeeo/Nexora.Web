@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Import Orders";
    var coreuiIcons = Url.Content("~/admin/assets/vendors/@coreui/icons/svg/free.svg");
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <div class="fs-4 fw-semibold">Import Orders</div>
        <div class="text-medium-emphasis">Upload Excel → Preview → Confirm Import</div>
    </div>

    <a class="btn btn-outline-primary" asp-controller="Imports" asp-action="OrdersTemplate">
        <svg class="icon me-2">
            <use href="@($"{coreuiIcons}#cil-cloud-download")" xlink:href="@($"{coreuiIcons}#cil-cloud-download")"></use>
        </svg>
        Download Template
    </a>
</div>

<div class="card">
    <div class="card-header fw-semibold">
        Upload Excel (.xlsx)
    </div>

    <div class="card-body">
        <form method="post" enctype="multipart/form-data" asp-controller="Imports" asp-action="OrdersPreview">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="form-label">Excel file</label>
                <input type="file" name="file" class="form-control" accept=".xlsx" required />
                <div class="form-text">
                    Use the template to avoid column/order issues.
                </div>
            </div>

            <button type="submit" class="btn btn-primary">
                <svg class="icon me-2">
                    <use href="@($"{coreuiIcons}#cil-magnifying-glass")" xlink:href="@($"{coreuiIcons}#cil-magnifying-glass")"></use>
                </svg>
                Preview Import
            </button>
        </form>
    </div>
</div>