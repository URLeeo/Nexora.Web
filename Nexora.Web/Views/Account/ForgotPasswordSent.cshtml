@{
    Layout = "_LandingLayout";
    ViewData["Title"] = "Check your email";
}

@await Html.PartialAsync("_LandingNavbar")

<section class="ud-page-banner">
    <div class="container">
        <div class="row"><div class="col-lg-12"><div class="ud-banner-content"><h1>Check your email</h1></div></div></div>
    </div>
</section>

<section class="ud-about" style="padding-top: 60px;">
    <div class="container">
        <div class="ud-single-feature" style="padding: 26px; max-width: 720px; margin: 0 auto;">
            <h3 style="margin:0 0 8px;">If an account exists, we sent a reset link.</h3>
            <p style="margin:0 0 14px; color:#6b7280;">Please check your inbox (and spam/junk folder).</p>
            <a class="ud-main-btn" href="/Account/Login">Back to login</a>
        </div>
    </div>
</section>
