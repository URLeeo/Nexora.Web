@{
    Layout = "_LandingLayout";
    ViewData["Title"] = "Reset link invalid";
}

@await Html.PartialAsync("_LandingNavbar")

<section class="ud-page-banner">
    <div class="container">
        <div class="row"><div class="col-lg-12"><div class="ud-banner-content"><h1>Reset link invalid</h1></div></div></div>
    </div>
</section>

<section class="ud-about" style="padding-top: 60px;">
    <div class="container">
        <div class="ud-single-feature" style="padding: 26px; max-width: 720px; margin: 0 auto;">
            <h3 style="margin:0 0 8px;">This reset link is invalid or expired.</h3>
            <p style="margin:0 0 14px; color:#6b7280;">Request a new one and try again.</p>
            <a class="ud-main-btn" href="/Account/ForgotPassword">Request new link</a>
        </div>
    </div>
</section>
