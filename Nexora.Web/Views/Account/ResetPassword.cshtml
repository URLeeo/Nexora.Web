@model Nexora.Web.Models.IdentityModels.ResetPasswordVm
@{
    Layout = "_LandingLayout";
    ViewData["Title"] = "Reset Password";
}

@await Html.PartialAsync("_LandingNavbar")

<section class="ud-page-banner">
    <div class="container">
        <div class="row"><div class="col-lg-12"><div class="ud-banner-content"><h1>Reset Password</h1></div></div></div>
    </div>
</section>

<section class="ud-login">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="ud-login-wrapper">
                    <div class="ud-login-logo">
                        <img src="~/brand/logo-auth.svg" alt="Nexora" style="max-width: 260px; height:auto;" />
                    </div>

                    <form class="ud-login-form" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="All" class="text-danger"></div>

                        <input type="hidden" asp-for="UserId" />
                        <input type="hidden" asp-for="Token" />

                        <div class="ud-form-group">
                            <input asp-for="NewPassword" type="password" placeholder="New password" />
                            <span asp-validation-for="NewPassword" class="text-danger"></span>
                        </div>

                        <div class="ud-form-group">
                            <input asp-for="ConfirmPassword" type="password" placeholder="Confirm new password" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>

                        <div class="ud-form-group">
                            <button type="submit" class="ud-main-btn w-100">Reset password</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
