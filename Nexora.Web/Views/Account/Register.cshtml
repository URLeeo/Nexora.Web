@model Nexora.Web.Models.IdentityModels.RegisterVm
@{
    Layout = "_LandingLayout";
    ViewData["Title"] = "Register";
}

<!-- ====== Header Start ====== -->
@await Html.PartialAsync("_LandingNavbar")
<!-- ====== Header End ====== -->
<!-- ====== Banner Start ====== -->
<section class="ud-page-banner">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="ud-banner-content">
                    <h1>Create Account</h1>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- ====== Banner End ====== -->
<!-- ====== Register Start ====== -->
<section class="ud-login">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="ud-login-wrapper">
                    <div class="ud-login-logo">
                        <img src="~/play/assets/images/logo/logo-2.svg" alt="logo" />
                    </div>

                    <form class="ud-login-form" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="All" class="text-danger"></div>

                        <div class="ud-form-group">
                            <input asp-for="FullName" placeholder="Full name" />
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>

                        <div class="ud-form-group">
                            <input asp-for="OrganizationName" placeholder="Organization name" />
                            <span asp-validation-for="OrganizationName" class="text-danger"></span>
                        </div>

                        <div class="ud-form-group">
                            <input asp-for="Email" type="email" placeholder="Email" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="ud-form-group">
                            <input asp-for="Password" type="password" placeholder="Password" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <div class="ud-form-group">
                            <button type="submit" class="ud-main-btn w-100">Create account</button>
                        </div>
                    </form>

                    <p class="signup-option">
                        Already have an account? <a href="/Account/Login"> Sign In </a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- ====== Register End ====== -->