@{
    Layout = "_LandingLayout";
    ViewData["Title"] = "Check your email";
}

<section class="ud-hero" style="padding-top:120px; padding-bottom:80px;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-7">
                <div class="card shadow-sm">
                    <div class="card-body p-4">
                        <h2 class="mb-2">Almost there ✅</h2>
                        <p class="text-medium-emphasis">
                            We sent a confirmation link to your email. Please confirm your email address to activate your Nexora account.
                        </p>
                        <div class="d-flex gap-2 mt-3">
                            <a class="btn btn-primary" href="/Account/Login">Go to Login</a>
                            <a class="btn btn-outline-secondary" href="/">Back to Home</a>
                        </div>
                        <div class="text-medium-emphasis small mt-3">
                            If you don't see the email, check Spam/Junk.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
