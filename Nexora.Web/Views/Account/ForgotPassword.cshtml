@model Nexora.Web.Models.IdentityModels.ForgotPasswordVm
@{
    Layout = "_LandingLayout";
    ViewData["Title"] = "Forgot Password";
}

@await Html.PartialAsync("_LandingNavbar")

<section class="ud-page-banner">
    <div class="container">
        <div class="row"><div class="col-lg-12"><div class="ud-banner-content"><h1>Forgot Password</h1></div></div></div>
    </div>
</section>

<section class="ud-login">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="ud-login-wrapper">
                    <div class="ud-login-logo">
                        <img src="~/brand/logo-auth.svg" alt="Nexora" style="max-width: 260px; height:auto;" />
                    </div>

                    <form class="ud-login-form" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="All" class="text-danger"></div>

                        <div class="ud-form-group">
                            <input asp-for="Email" type="email" placeholder="Your email" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="ud-form-group">
                            <button type="submit" class="ud-main-btn w-100">Send reset link</button>
                        </div>
                    </form>

                    <p class="signup-option">
                        Remembered it? <a href="/Account/Login">Back to login</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>
