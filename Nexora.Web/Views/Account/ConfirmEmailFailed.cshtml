@{
    Layout = "_LandingLayout";
    ViewData["Title"] = "Confirmation failed";
}

<section class="ud-hero" style="padding-top:120px; padding-bottom:80px;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-7">
                <div class="card shadow-sm">
                    <div class="card-body p-4">
                        <h2 class="mb-2">Confirmation failed</h2>
                        <p class="text-medium-emphasis">
                            This confirmation link is invalid or expired.
                        </p>
                        <div class="d-flex gap-2 mt-3">
                            <a class="btn btn-primary" href="/Account/Register">Register again</a>
                            <a class="btn btn-outline-secondary" href="/">Back to Home</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
