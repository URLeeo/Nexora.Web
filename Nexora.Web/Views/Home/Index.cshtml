<!-- ====== Back To Top End ====== -->
@section Scripts {
    <script>
        // ==== smooth scroll + works with both "#id" and "/#id"
        const pageLink = document.querySelectorAll(".ud-menu-scroll");

        pageLink.forEach((elem) => {
            elem.addEventListener("click", (e) => {
                const rawHref = elem.getAttribute("href");
                if (!rawHref) return;

                const hashIndex = rawHref.indexOf("#");
                const hash = hashIndex >= 0 ? rawHref.substring(hashIndex) : null;

                if (!hash) return;

                if (window.location.pathname !== "/") {
                    return;
                }

                e.preventDefault();

                const target = document.querySelector(hash);
                if (!target) return;

                const headerOffset = 73;
                const elementPosition = target.getBoundingClientRect().top + window.pageYOffset;
                const offsetPosition = elementPosition - headerOffset;

                window.scrollTo({
                    top: offsetPosition,
                    behavior: "smooth"
                });
            });
        });

        function onScroll() {
            const links = document.querySelectorAll(".ud-menu-scroll");
            const scrollPos = window.pageYOffset || document.documentElement.scrollTop || document.body.scrollTop;
            const headerOffset = 73;

            links.forEach((link) => {
                const rawHref = link.getAttribute("href");
                if (!rawHref) return;

                const hashIndex = rawHref.indexOf("#");
                if (hashIndex < 0) return;

                const hash = rawHref.substring(hashIndex);
                const section = document.querySelector(hash);
                if (!section) return;

                const top = section.offsetTop - headerOffset;
                const bottom = top + section.offsetHeight;

                if (scrollPos >= top && scrollPos < bottom) {
                    links.forEach(l => l.classList.remove("active"));
                    link.classList.add("active");
                }
            });
        }

        window.addEventListener("scroll", onScroll);
    </script>
}