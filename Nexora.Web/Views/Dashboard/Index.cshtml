@model Nexora.Web.Models.DashboardVm

@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Dashboard";
    var coreuiIcons = Url.Content("~/admin/assets/vendors/@coreui/icons/svg/free.svg");
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <div class="fs-4 fw-semibold">Dashboard</div>
        <div class="text-medium-emphasis">Overview of your business</div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-medium-emphasis small">Revenue (30d)</div>
                    <div class="fs-3 fw-semibold">@Model.RevenueLast30Days</div>
                </div>
                <svg class="icon icon-xl">
                    <use href="@($"{coreuiIcons}#cil-dollar")" xlink:href="@($"{coreuiIcons}#cil-dollar")"></use>
                </svg>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-medium-emphasis small">Orders (30d)</div>
                    <div class="fs-3 fw-semibold">@Model.OrdersLast30Days</div>
                </div>
                <svg class="icon icon-xl">
                    <use href="@($"{coreuiIcons}#cil-cart")" xlink:href="@($"{coreuiIcons}#cil-cart")"></use>
                </svg>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-medium-emphasis small">Customers</div>
                    <div class="fs-3 fw-semibold">@Model.CustomersCount</div>
                </div>
                <svg class="icon icon-xl">
                    <use href="@($"{coreuiIcons}#cil-user")" xlink:href="@($"{coreuiIcons}#cil-user")"></use>
                </svg>
            </div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header fw-semibold d-flex align-items-center justify-content-between">
        <div>
            <svg class="icon me-2">
                <use href="@($"{coreuiIcons}#cil-warning")" xlink:href="@($"{coreuiIcons}#cil-warning")"></use>
            </svg>
            Low Stock Products
        </div>
        <span class="badge bg-warning">@Model.LowStockProducts.Count</span>
    </div>

    <div class="card-body">
        @if (Model.LowStockProducts.Count == 0)
        {
            <div class="text-center py-4 text-medium-emphasis">No low stock alerts 🎉</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Product</th>
                            <th class="text-nowrap">Stock</th>
                            <th class="text-nowrap">Threshold</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model.LowStockProducts)
                        {
                            <tr>
                                <td class="fw-semibold">@p.Name</td>
                                <td class="text-nowrap">
                                    <span class="badge bg-warning">@p.StockOnHand</span>
                                </td>
                                <td class="text-nowrap">@p.Threshold</td>
                                <td class="text-end">
                                    <a class="btn btn-sm btn-outline-primary"
                                       asp-controller="Products"
                                       asp-action="Edit"
                                       asp-route-id="@p.Id">
                                        <svg class="icon me-1">
                                            <use href="@($"{coreuiIcons}#cil-pencil")" xlink:href="@($"{coreuiIcons}#cil-pencil")"></use>
                                        </svg>
                                        Update
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<div class="card mb-4">
    <div class="card-header fw-semibold d-flex align-items-center justify-content-between">
        <div>
            <svg class="icon me-2">
                <use href="@($"{coreuiIcons}#cil-chart-line")" xlink:href="@($"{coreuiIcons}#cil-chart-line")"></use>
            </svg>
            Sales (Last 7 Days)
        </div>
        <span class="badge bg-info">@Model.SalesLast7Days.Sum(x => x.OrdersCount) orders</span>
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Date</th>
                        <th class="text-nowrap">Orders</th>
                        <th class="text-nowrap">Revenue</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in Model.SalesLast7Days)
                    {
                        <tr>
                            <td class="text-nowrap">@d.DateUtc.ToLocalTime().ToString("yyyy-MM-dd")</td>
                            <td class="text-nowrap">@d.OrdersCount</td>
                            <td class="text-nowrap">@d.Revenue</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>