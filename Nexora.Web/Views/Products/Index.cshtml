@model List<Nexora.Web.Data.Models.Product>

@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Products";
}

<h2>Products</h2>

<form method="get" style="margin-bottom:12px;">
    <input name="q" value="@ViewBag.Q" placeholder="Search name / sku" />
    <button type="submit">Search</button>
    <a href="/Products/Create" style="margin-left:12px;">+ New Product</a>
</form>

<table>
    <thead>
        <tr>
            <th>Name</th>
            <th>SKU</th>
            <th>Category</th>
            <th>Price</th>
            <th>Stock</th>
            <th>Active</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.Name</td>
                <td>@p.Sku</td>
                <td>@p.Category?.Name</td>
                <td>@p.SalePrice</td>
                <td>@p.StockOnHand</td>
                <td>@p.IsActive</td>
                <td>
                    <a href="/Products/Edit/@p.Id">Edit</a>

                    <form method="post" action="/Products/Delete/@p.Id" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <button type="submit">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>