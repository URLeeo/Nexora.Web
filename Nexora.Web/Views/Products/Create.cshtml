@model Nexora.Web.Models.ProductModels.ProductCreateVm
@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Create Product";
    var coreuiIcons = Url.Content("~/admin/assets/vendors/@coreui/icons/svg/free.svg");
    var categories = ViewBag.Categories as List<Nexora.Web.Data.Models.Category> ?? new();
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <div class="fs-4 fw-semibold">Create Product</div>
        <div class="text-medium-emphasis">Add a new product</div>
    </div>

    <a class="btn btn-outline-secondary" asp-controller="Products" asp-action="Index">
        <svg class="icon me-2">
            <use href="@($"{coreuiIcons}#cil-arrow-left")" xlink:href="@($"{coreuiIcons}#cil-arrow-left")"></use>
        </svg>
        Back
    </a>
</div>

<div class="card mb-4">
    <div class="card-header fw-semibold">
        <svg class="icon me-2">
            <use href="@($"{coreuiIcons}#cil-plus")" xlink:href="@($"{coreuiIcons}#cil-plus")"></use>
        </svg>
        New Product
    </div>

    <div class="card-body">
        <form method="post" asp-controller="Products" asp-action="Create" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Name</label>
                    <input class="form-control" asp-for="Name" placeholder="e.g. iPhone 15 Pro" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label">SKU</label>
                    <input class="form-control" asp-for="Sku" placeholder="Optional" />
                    <span asp-validation-for="Sku" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Category</label>
                    <select class="form-select" asp-for="CategoryId">
                        <option value="">-- Select category --</option>
                        @foreach (var c in categories)
                        {
                            <option value="@c.Id" selected="@(c.Id == Model.CategoryId)">@c.Name</option>
                        }
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger small"></span>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Sale price</label>
                    <input class="form-control" asp-for="SalePrice" />
                    <span asp-validation-for="SalePrice" class="text-danger small"></span>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Cost price</label>
                    <input class="form-control" asp-for="CostPrice" />
                    <span asp-validation-for="CostPrice" class="text-danger small"></span>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Stock on hand</label>
                    <input class="form-control" asp-for="StockOnHand" />
                    <span asp-validation-for="StockOnHand" class="text-danger small"></span>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Low stock threshold</label>
                    <input class="form-control" asp-for="LowStockThreshold" />
                    <span asp-validation-for="LowStockThreshold" class="text-danger small"></span>
                </div>

                <div class="col-md-3 d-flex align-items-end">
                    <div class="form-check">
                        <input class="form-check-input" asp-for="IsActive" />
                        <label class="form-check-label" asp-for="IsActive">Active</label>
                    </div>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Product image (optional)</label>
                    <input class="form-control" asp-for="ImageFile" type="file" accept="image/*" />
                    <div class="text-medium-emphasis small mt-1">PNG/JPG/WEBP up to 2MB.</div>
                    <span asp-validation-for="ImageFile" class="text-danger small"></span>

                    <!-- Preview -->
                    <div class="mt-2">
                        <div class="border rounded p-2" style="max-width:260px">
                            <img id="imgPreview"
                                 alt="preview"
                                 style="display:none; max-width:100%; height:auto; border-radius:10px;" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">
                    <svg class="icon me-2">
                        <use href="@($"{coreuiIcons}#cil-save")" xlink:href="@($"{coreuiIcons}#cil-save")"></use>
                    </svg>
                    Create
                </button>
                <a class="btn btn-light" asp-controller="Products" asp-action="Index">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const input = document.querySelector('input[name="ImageFile"]');
            const img = document.getElementById('imgPreview');

            if (!input || !img) return;

            input.addEventListener('change', function () {
                const file = input.files && input.files[0];
                if (!file) {
                    img.style.display = 'none';
                    img.removeAttribute('src');
                    return;
                }

                const url = URL.createObjectURL(file);
                img.src = url;
                img.style.display = 'block';
            });
        })();
    </script>
}