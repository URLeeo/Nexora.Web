@model Nexora.Web.Models.ProductModels.ProductCreateVm
@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Create Product";
    var coreuiIcons = Url.Content("~/admin/assets/vendors/@coreui/icons/svg/free.svg");
    var categories = ViewBag.Categories as List<Nexora.Web.Data.Models.Category> ?? new();
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <div class="fs-4 fw-semibold">Create Product</div>
        <div class="text-medium-emphasis">Add a new product</div>
    </div>

    <a class="btn btn-outline-secondary" asp-controller="Products" asp-action="Index">
        <svg class="icon me-2">
            <use href="@($"{coreuiIcons}#cil-arrow-left")" xlink:href="@($"{coreuiIcons}#cil-arrow-left")"></use>
        </svg>
        Back
    </a>
</div>

<div class="card mb-4">
    <div class="card-header fw-semibold">
        <svg class="icon me-2">
            <use href="@($"{coreuiIcons}#cil-plus")" xlink:href="@($"{coreuiIcons}#cil-plus")"></use>
        </svg>
        New Product
    </div>

    <div class="card-body">
        <form method="post" asp-controller="Products" asp-action="Create">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Name</label>
                    <input class="form-control" asp-for="Name" placeholder="e.g. iPhone 15 Pro" />
                </div>

                <div class="col-md-6">
                    <label class="form-label">SKU</label>
                    <input class="form-control" asp-for="Sku" placeholder="Optional" />
                </div>

                <div class="col-md-6">
                    <label class="form-label">Category</label>
                    <select class="form-select" asp-for="CategoryId">
                        <option value="">-- Select category --</option>
                        @foreach (var c in categories)
                        {
                            <option value="@c.Id" selected="@(c.Id == Model.CategoryId)">@c.Name</option>
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Sale price</label>
                    <input class="form-control" asp-for="SalePrice" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Cost price</label>
                    <input class="form-control" asp-for="CostPrice" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Stock on hand</label>
                    <input class="form-control" asp-for="StockOnHand" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Low stock threshold</label>
                    <input class="form-control" asp-for="LowStockThreshold" />
                </div>

                <div class="col-md-3 d-flex align-items-end">
                    <div class="form-check">
                        <input class="form-check-input" asp-for="IsActive" />
                        <label class="form-check-label" for="IsActive">Active</label>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">
                    <svg class="icon me-2">
                        <use href="@($"{coreuiIcons}#cil-save")" xlink:href="@($"{coreuiIcons}#cil-save")"></use>
                    </svg>
                    Create
                </button>
                <a class="btn btn-light" asp-controller="Products" asp-action="Index">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}