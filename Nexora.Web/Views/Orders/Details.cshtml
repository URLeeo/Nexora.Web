@model Nexora.Web.Data.Models.Order

@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Order Details";
    var coreuiIcons = Url.Content("~/admin/assets/vendors/@coreui/icons/svg/free.svg");
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <div class="fs-4 fw-semibold">Order @Model.OrderNo</div>
        <div class="text-medium-emphasis">View order details</div>
    </div>

    <a class="btn btn-outline-secondary" asp-controller="Orders" asp-action="Index">
        <svg class="icon me-2">
            <use href="@($"{coreuiIcons}#cil-arrow-left")" xlink:href="@($"{coreuiIcons}#cil-arrow-left")"></use>
        </svg>
        Back
    </a>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card">
            <div class="card-header fw-semibold">
                <svg class="icon me-2">
                    <use href="@($"{coreuiIcons}#cil-user")" xlink:href="@($"{coreuiIcons}#cil-user")"></use>
                </svg>
                Customer
            </div>
            <div class="card-body">
                <div class="fw-semibold">@(Model.Customer?.FullName ?? "-")</div>
                <div class="text-medium-emphasis small">Status: @Model.Status</div>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card">
            <div class="card-header fw-semibold">
                <svg class="icon me-2">
                    <use href="@($"{coreuiIcons}#cil-dollar")" xlink:href="@($"{coreuiIcons}#cil-dollar")"></use>
                </svg>
                Summary
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-3">
                        <div class="text-medium-emphasis small">Subtotal</div>
                        <div class="fw-semibold">@Model.Subtotal</div>
                    </div>
                    <div class="col-md-3">
                        <div class="text-medium-emphasis small">Discount</div>
                        <div class="fw-semibold">@Model.DiscountAmount</div>
                    </div>
                    <div class="col-md-3">
                        <div class="text-medium-emphasis small">Tax</div>
                        <div class="fw-semibold">@Model.TaxAmount</div>
                    </div>
                    <div class="col-md-3">
                        <div class="text-medium-emphasis small">Total</div>
                        <div class="fw-semibold">@Model.Total</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card mt-3 mb-4">
    <div class="card-header fw-semibold">
        <svg class="icon me-2">
            <use href="@($"{coreuiIcons}#cil-list")" xlink:href="@($"{coreuiIcons}#cil-list")"></use>
        </svg>
        Items
        <span class="badge bg-info ms-2">@Model.Items.Count</span>
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Product</th>
                        <th class="text-nowrap">Qty</th>
                        <th class="text-nowrap">Unit</th>
                        <th class="text-nowrap">Line total</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var i in Model.Items)
                    {
                        <tr>
                            <td>@(i.Product?.Name ?? "-")</td>
                            <td class="text-nowrap">@i.Quantity</td>
                            <td class="text-nowrap">@i.UnitPrice</td>
                            <td class="text-nowrap">@i.LineTotal</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>