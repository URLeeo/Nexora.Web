@model Nexora.Web.Models.OrderModels.OrderCreateVm
@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Create Order";

    var coreuiIcons = Url.Content("~/admin/assets/vendors/@coreui/icons/svg/free.svg");
    var customers = ViewBag.Customers as List<Nexora.Web.Data.Models.Customer> ?? new();
    var products = ViewBag.Products as List<Nexora.Web.Data.Models.Product> ?? new();
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <div class="fs-4 fw-semibold">Create Order</div>
        <div class="text-medium-emphasis">Create a new order and add items</div>
    </div>

    <a class="btn btn-outline-secondary" asp-controller="Orders" asp-action="Index">
        <svg class="icon me-2">
            <use href="@($"{coreuiIcons}#cil-arrow-left")" xlink:href="@($"{coreuiIcons}#cil-arrow-left")"></use>
        </svg>
        Back
    </a>
</div>

<div class="card mb-4">
    <div class="card-header fw-semibold">
        <svg class="icon me-2">
            <use href="@($"{coreuiIcons}#cil-cart")" xlink:href="@($"{coreuiIcons}#cil-cart")"></use>
        </svg>
        New Order
    </div>

    <div class="card-body">
        <form method="post" asp-controller="Orders" asp-action="Create">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <!-- Customer -->
            <div class="mb-3">
                <label class="form-label">Customer (optional)</label>
                <select class="form-select" asp-for="CustomerId">
                    <option value="">-- none --</option>
                    @foreach (var c in customers)
                    {
                        <option value="@c.Id">@c.FullName</option>
                    }
                </select>
                <div class="form-text">You can create an order without a customer.</div>
            </div>

            <hr class="my-4" />

            <!-- Items -->
            <div class="d-flex align-items-center justify-content-between mb-2">
                <div class="fw-semibold">
                    <svg class="icon me-2">
                        <use href="@($"{coreuiIcons}#cil-list")" xlink:href="@($"{coreuiIcons}#cil-list")"></use>
                    </svg>
                    Items
                </div>
                <div class="d-flex align-items-center gap-2">
                    <span class="badge bg-info" id="itemsCountBadge">@Model.Items.Count</span>
                    <button type="button" class="btn btn-sm btn-outline-primary" id="addItemBtn">
                        <svg class="icon me-1">
                            <use href="@($"{coreuiIcons}#cil-plus")" xlink:href="@($"{coreuiIcons}#cil-plus")"></use>
                        </svg>
                        Add item
                    </button>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="min-width:320px;">Product</th>
                            <th class="text-nowrap" style="width:140px;">Qty</th>
                            <th class="text-nowrap" style="width:180px;">Unit price</th>
                            <th style="width:90px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Items.Count; i++)
                        {
                            <tr>
                                <td>
                                    <select class="form-select" name="Items[@i].ProductId">
                                        <option value="">-- select --</option>
                                        @foreach (var p in products)
                                        {
                                            <option value="@p.Id" data-price="@p.SalePrice">@p.Name (stock: @p.StockOnHand)</option>
                                        }
                                    </select>
                                </td>

                                <td>
                                    <input class="form-control"
                                           name="Items[@i].Quantity"
                                           value="@(Model.Items[i].Quantity == 0 ? 1 : Model.Items[i].Quantity)"
                                           inputmode="numeric" />
                                </td>

                                <td>
                                    <input class="form-control"
                                           name="Items[@i].UnitPrice"
                                           value="@(Model.Items[i].UnitPrice)"
                                           inputmode="decimal" />
                                </td>

                                <td class="text-end">
                                    <button type="button" class="btn btn-sm btn-outline-danger removeItemBtn" title="Remove">
                                        <svg class="icon">
                                            <use href="@($"{coreuiIcons}#cil-trash")" xlink:href="@($"{coreuiIcons}#cil-trash")"></use>
                                        </svg>
                                    </button>
                                </td>
                            </tr>
                        }
                    
                        <tr id="itemRowTemplate" class="d-none">
                            <td>
                                <select class="form-select" name="Items[__i__].ProductId">
                                    <option value="">-- select --</option>
                                    @foreach (var p in products)
                                    {
                                        <option value="@p.Id" data-price="@p.SalePrice">@p.Name (stock: @p.StockOnHand)</option>
                                    }
                                </select>
                            </td>
                            <td>
                                <input class="form-control" name="Items[__i__].Quantity" value="1" inputmode="numeric" />
                            </td>
                            <td>
                                <input class="form-control" name="Items[__i__].UnitPrice" value="" inputmode="decimal" />
                            </td>
                            <td class="text-end">
                                <button type="button" class="btn btn-sm btn-outline-danger removeItemBtn" title="Remove">
                                    <svg class="icon">
                                        <use href="@($"{coreuiIcons}#cil-trash")" xlink:href="@($"{coreuiIcons}#cil-trash")"></use>
                                    </svg>
                                </button>
                            </td>
                        </tr>

                    </tbody>
                </table>
            </div>


            <hr class="my-4" />

            <!-- Discount / Tax -->
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Discount</label>
                    <input class="form-control" asp-for="DiscountAmount" />
                </div>

                <div class="col-md-6">
                    <label class="form-label">Tax</label>
                    <input class="form-control" asp-for="TaxAmount" />
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">
                    <svg class="icon me-2">
                        <use href="@($"{coreuiIcons}#cil-save")" xlink:href="@($"{coreuiIcons}#cil-save")"></use>
                    </svg>
                    Create Order
                </button>

                <a class="btn btn-light" asp-controller="Orders" asp-action="Index">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const tbody = document.querySelector('table tbody');
            const tpl = document.getElementById('itemRowTemplate');
            const addBtn = document.getElementById('addItemBtn');
            const badge = document.getElementById('itemsCountBadge');

            function wirePriceSelect(row) {
                const sel = row.querySelector('select[name$="].ProductId"]');
                if (!sel) return;

                sel.addEventListener('change', () => {
                    const opt = sel.options[sel.selectedIndex];
                    const price = opt?.dataset?.price;

                    const match = sel.name.match(/Items\[(\d+)\]\.ProductId/);
                    if (!match) return;

                    const idx = match[1];
                    const unitInput = document.querySelector(`input[name="Items[${idx}].UnitPrice"]`);
                    if (!unitInput) return;

                    if (price !== undefined && price !== null && price !== "") {
                        unitInput.value = price;
                    }
                });
            }

            function getRows() {
                return Array.from(tbody.querySelectorAll('tr'))
                    .filter(r => r.id !== 'itemRowTemplate' && !r.classList.contains('d-none'));
            }

            function reindexRows() {
                const rows = getRows();

                rows.forEach((row, i) => {
                    row.querySelectorAll('select, input').forEach(el => {
                        const n = el.getAttribute('name');
                        if (!n) return;
                        el.setAttribute('name', n.replace(/Items\[\d+\]/g, `Items[${i}]`));
                    });
                    wirePriceSelect(row);
                });

                if (badge) badge.textContent = rows.length.toString();
            }

            function addRow() {
                const nextIdx = getRows().length;

                const html = tpl.outerHTML.replaceAll('__i__', nextIdx.toString());
                const tmp = document.createElement('tbody');
                tmp.innerHTML = html;

                const newRow = tmp.firstElementChild;
                newRow.classList.remove('d-none');
                newRow.removeAttribute('id');

                tbody.appendChild(newRow);
                reindexRows();
            }

            function removeRow(btn) {
                const row = btn.closest('tr');
                if (!row) return;

                const rows = getRows();
                if (rows.length <= 1) return; // keep at least 1 row

                row.remove();
                reindexRows();
            }

            tbody.addEventListener('click', (e) => {
                const btn = e.target.closest('.removeItemBtn');
                if (!btn) return;
                removeRow(btn);
            });

            addBtn?.addEventListener('click', addRow);

            // wire existing row(s)
            getRows().forEach(r => wirePriceSelect(r));
            reindexRows();
        })();
    </script>
}
