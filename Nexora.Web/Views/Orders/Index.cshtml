@model List<Nexora.Web.Data.Models.Order>

@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Orders";
    var coreuiIcons = Url.Content("~/admin/assets/vendors/@coreui/icons/svg/free.svg");
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <div class="fs-4 fw-semibold">Orders</div>
        <div class="text-medium-emphasis">Manage your orders</div>
    </div>

    <a class="btn btn-primary" asp-controller="Orders" asp-action="Create">
        <svg class="icon me-2">
            <use href="@($"{coreuiIcons}#cil-plus")" xlink:href="@($"{coreuiIcons}#cil-plus")"></use>
        </svg>
        New Order
    </a>
</div>

<div class="card mb-4">
    <div class="card-header fw-semibold">
        <svg class="icon me-2">
            <use href="@($"{coreuiIcons}#cil-cart")" xlink:href="@($"{coreuiIcons}#cil-cart")"></use>
        </svg>
        Order List
        <span class="badge bg-info ms-2">@Model.Count</span>
    </div>

    <div class="card-body">
        @if (Model.Count == 0)
        {
            <div class="text-center py-5">
                <div class="text-medium-emphasis mb-2">No orders found.</div>
                <a class="btn btn-primary" asp-controller="Orders" asp-action="Create">Create your first order</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Order No</th>
                            <th>Customer</th>
                            <th class="text-nowrap">Status</th>
                            <th class="text-nowrap">Total</th>
                            <th class="text-nowrap">Created</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@o.OrderNo</td>
                                <td>@(o.Customer?.FullName ?? "-")</td>
                                <td class="text-nowrap">
                                    <span class="badge bg-primary">@o.Status</span>
                                </td>
                                <td class="text-nowrap">@o.Total</td>
                                <td class="text-nowrap">@o.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                <td class="text-end">
                                    <a class="btn btn-sm btn-outline-primary"
                                       asp-controller="Orders"
                                       asp-action="Details"
                                       asp-route-id="@o.Id">
                                        <svg class="icon me-1">
                                            <use href="@($"{coreuiIcons}#cil-description")" xlink:href="@($"{coreuiIcons}#cil-description")"></use>
                                        </svg>
                                        Details
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>