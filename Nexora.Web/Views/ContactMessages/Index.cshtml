@model List<Nexora.Web.Data.Entities.ContactMessage>
@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Contact Messages";

    var coreuiIcons = Url.Content("~/admin/assets/vendors/@coreui/icons/svg/free.svg");
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <div class="fs-4 fw-semibold">Contact Messages</div>
        <div class="text-medium-emphasis">Messages submitted from the landing page</div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header fw-semibold">
        <svg class="icon me-2">
            <use href="@($"{coreuiIcons}#cil-envelope-closed")" xlink:href="@($"{coreuiIcons}#cil-envelope-closed")"></use>
        </svg>
        Inbox
        <span class="badge bg-secondary ms-2">@Model.Count</span>
    </div>

    <div class="card-body">
        @if (Model.Count == 0)
        {
            <div class="text-medium-emphasis">No messages yet.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width:70px;">Status</th>
                            <th style="min-width:200px;">Name</th>
                            <th style="min-width:220px;">Email</th>
                            <th>Message</th>
                            <th class="text-nowrap" style="width:170px;">Received</th>
                            <th style="width:120px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var m in Model)
                    {
                        <tr>
                            <td>
                                @if (m.IsRead)
                                {
                                    <span class="badge bg-light text-dark">Read</span>
                                }
                                else
                                {
                                    <span class="badge bg-primary">New</span>
                                }
                            </td>
                            <td>@m.FullName</td>
                            <td>@m.Email</td>
                            <td class="text-truncate" style="max-width:520px;">@m.Message</td>
                            <td class="text-nowrap">@m.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@m.Id">Open</a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
