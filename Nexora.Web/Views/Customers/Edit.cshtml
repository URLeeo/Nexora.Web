@model Nexora.Web.Data.Models.Customer

@{
    Layout = "_AppLayout";
    ViewData["Title"] = "Edit Customer";
    var coreuiIcons = Url.Content("~/admin/assets/vendors/@coreui/icons/svg/free.svg");
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <div class="fs-4 fw-semibold">Edit Customer</div>
        <div class="text-medium-emphasis">Update customer details</div>
    </div>

    <a class="btn btn-outline-secondary" asp-controller="Customers" asp-action="Index">
        <svg class="icon me-2">
            <use href="@($"{coreuiIcons}#cil-arrow-left")" xlink:href="@($"{coreuiIcons}#cil-arrow-left")"></use>
        </svg>
        Back
    </a>
</div>

<div class="card mb-4">
    <div class="card-header fw-semibold">
        <svg class="icon me-2">
            <use href="@($"{coreuiIcons}#cil-pencil")" xlink:href="@($"{coreuiIcons}#cil-pencil")"></use>
        </svg>
        Edit Customer
    </div>

    <div class="card-body">
        <form method="post" asp-controller="Customers" asp-action="Edit">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label class="form-label">Full name</label>
                <input class="form-control" asp-for="FullName" autocomplete="off" />
            </div>

            <div class="mb-3">
                <label class="form-label">Phone</label>
                <input class="form-control" asp-for="Phone" autocomplete="off" />
            </div>

            <div class="mb-3">
                <label class="form-label">Email</label>
                <input class="form-control" asp-for="Email" autocomplete="off" />
            </div>

            <div class="mb-3">
                <label class="form-label">Notes</label>
                <textarea class="form-control" asp-for="Notes" rows="3"></textarea>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <svg class="icon me-2">
                        <use href="@($"{coreuiIcons}#cil-save")" xlink:href="@($"{coreuiIcons}#cil-save")"></use>
                    </svg>
                    Save
                </button>
                <a class="btn btn-light" asp-controller="Customers" asp-action="Index">Cancel</a>
            </div>
        </form>
    </div>
</div>