@using Microsoft.AspNetCore.Identity
@{
    var coreuiIcons = Url.Content("~/admin/assets/vendors/@coreui/icons/svg/free.svg");
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Nexora</title>

    <link rel="icon" type="image/png" href="~/admin/assets/favicon/favicon.png" />

    <!-- CoreUI CSS -->
    <link rel="stylesheet" href="~/admin/assets/vendors/simplebar/css/simplebar.css" />
    <link rel="stylesheet" href="~/admin/assets/css/vendors/simplebar.css" />
    <link rel="stylesheet" href="~/admin/assets/css/style.css" />

    @RenderSection("Styles", required: false)
</head>
<body>
    <!-- Sidebar -->
    <div class="sidebar sidebar-dark sidebar-fixed" id="sidebar">
        <div class="sidebar-brand d-none d-md-flex">
            <a href="/Dashboard" class="sidebar-brand-full text-decoration-none text-white fw-bold d-flex align-items-center gap-2">
                <img src="~/play/assets/images/favicon.svg" width="22" height="22" alt="Nexora" />
                <span style="font-size:18px;">Nexora</span>
            </a>
        </div>

        <ul class="sidebar-nav" data-coreui="navigation" data-simplebar="">
            <li class="nav-item">
                <a class="nav-link" href="/Dashboard">
                    <span class="nav-icon">
                        <svg class="icon">
                            <use href="@($"{coreuiIcons}#cil-speedometer")"
                                 xlink:href="@($"{coreuiIcons}#cil-speedometer")"></use>
                        </svg>
                    </span>
                    Dashboard
                </a>
            </li>

            <li class="nav-title">Management</li>

            <li class="nav-item">
                <a class="nav-link" href="/Products">
                    <span class="nav-icon">
                        <svg class="icon">
                            <use href="@($"{coreuiIcons}#cil-list")"
                                 xlink:href="@($"{coreuiIcons}#cil-list")"></use>
                        </svg>
                    </span>
                    Products
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link" href="/Categories">
                    <span class="nav-icon">
                        <svg class="icon">
                            <use href="@($"{coreuiIcons}#cil-tags")"
                                 xlink:href="@($"{coreuiIcons}#cil-tags")"></use>
                        </svg>
                    </span>
                    Categories
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link" href="/Customers">
                    <span class="nav-icon">
                        <svg class="icon">
                            <use href="@($"{coreuiIcons}#cil-user")"
                                 xlink:href="@($"{coreuiIcons}#cil-user")"></use>
                        </svg>
                    </span>
                    Customers
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link" href="/Orders">
                    <span class="nav-icon">
                        <svg class="icon">
                            <use href="@($"{coreuiIcons}#cil-cart")"
                                 xlink:href="@($"{coreuiIcons}#cil-cart")"></use>
                        </svg>
                    </span>
                    Orders
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link" href="/Imports/Orders">
                    <span class="nav-icon">
                        <svg class="icon">
                            <use href="@($"{coreuiIcons}#cil-cloud-upload")"
                                 xlink:href="@($"{coreuiIcons}#cil-cloud-upload")"></use>
                        </svg>
                    </span>
                    Import Orders
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link" href="/Home">
                    <span class="nav-icon">
                        <svg class="icon">
                            <use href="@($"{coreuiIcons}#cil-home")"
                                 xlink:href="@($"{coreuiIcons}#cil-home")"></use>
                        </svg>
                    </span>
                    Back To Home
                </a>
            </li>
        </ul>

        <button class="sidebar-toggler" type="button" data-coreui-toggle="unfoldable"></button>
    </div>

    <!-- Wrapper -->
    <div class="wrapper d-flex flex-column min-vh-100 bg-light">
        <!-- Header -->
        <header class="header header-sticky mb-4">
            <div class="container-fluid">

                <button class="header-toggler px-md-0 me-md-3" type="button"
                        onclick="coreui.Sidebar.getInstance(document.querySelector('#sidebar')).toggle()">
                    <svg class="icon icon-lg">
                        <use href="@($"{coreuiIcons}#cil-menu")"
                             xlink:href="@($"{coreuiIcons}#cil-menu")"></use>
                    </svg>
                </button>

                <ul class="header-nav ms-auto">
                    <li class="nav-item me-2">
                        <a class="nav-link" href="/" title="Back to landing">
                            <svg class="icon">
                                <use href="@($"{coreuiIcons}#cil-home")"
                                     xlink:href="@($"{coreuiIcons}#cil-home")"></use>
                            </svg>
                        </a>
                    </li>

                    <li class="nav-item">
                        <form method="post" action="/Account/Logout" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                Logout
                            </button>
                        </form>
                    </li>
                </ul>
            </div>
        </header>

        <!-- Main -->
        <div class="body flex-grow-1 px-3">
            <div class="container-lg">

                @* ✅ Global alerts *@
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <div class="fw-semibold">@TempData["Success"]</div>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <div class="fw-semibold">@TempData["Error"]</div>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @RenderBody()
            </div>
        </div>

        <!-- Footer -->
        <footer class="footer">
            <div>Nexora © @DateTime.UtcNow.Year</div>
        </footer>
    </div>

    <!-- CoreUI JS -->
    <script src="~/admin/assets/vendors/@@coreui/coreui/js/coreui.bundle.min.js"></script>
    <script src="~/admin/assets/vendors/simplebar/js/simplebar.min.js"></script>
    <script src="~/admin/assets/js/main.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>